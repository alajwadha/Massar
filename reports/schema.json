{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Masaar gate report",
  "description": "One validation-gate review by one agent for one customer plan.",
  "type": "object",
  "required": ["slug", "date", "cycle", "agent", "verdict", "findings"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "description": "The customer plan slug reviewed." },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "cycle": { "type": "integer", "minimum": 1, "description": "Which full gate run this belongs to." },
    "agent": { "type": "integer", "enum": [1, 2, 3] },
    "verdict": { "type": "string", "enum": ["PASS", "FAIL"] },
    "findings": {
      "type": "array",
      "description": "Empty on PASS. One entry per finding on FAIL.",
      "items": {
        "type": "object",
        "required": ["criterion", "severity", "item", "evidence", "fix"],
        "additionalProperties": false,
        "properties": {
          "criterion": {
            "type": "string",
            "enum": [
              "relevance",
              "universities",
              "world_class",
              "grounding",
              "generic_content",
              "honesty",
              "scoring",
              "technical",
              "voice_gender",
              "links",
              "cross_check"
            ]
          },
          "severity": { "type": "string", "enum": ["fail", "warn"] },
          "item": { "type": "string", "description": "The exact thing that is wrong (a cert, a university, a label)." },
          "evidence": { "type": "string", "description": "Plan field or code reference. NEVER a quote from the CV." },
          "fix": { "type": "string", "description": "What to change, concretely." }
        }
      }
    },
    "notes": { "type": "string", "description": "Optional context that is not a finding." }
  }
}
