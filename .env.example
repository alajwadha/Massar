# Supabase (Phase 1)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API — CV scoring (server only)
ANTHROPIC_API_KEY=

# Moyasar — Saudi payments (mada, Apple Pay)
MOYASAR_PUBLISHABLE_KEY=
MOYASAR_SECRET_KEY=

# Resend — transactional email
RESEND_API_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin HR dashboard protection (/admin). Set these in Vercel so it isn't public.
# If ADMIN_PASSWORD is unset, /admin returns 404 (hidden) by default.
ADMIN_USER=admin
ADMIN_PASSWORD=
